root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc,ts,tsx,js,jsx,css,html,yml,yaml}]
indent_style = space
indent_size = 2

[*.gd]
indent_style = tab
indent_size = 4

[*.{kt,kts,swift}]
indent_style = space
indent_size = 4
max_line_length = 140
