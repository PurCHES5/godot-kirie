{
  "compilerOptions": {
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "target": "ESNext",
    "types": ["node", "vite/client"],
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts", "vite.config.ts"]
}
